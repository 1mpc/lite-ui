{
  "name": "vue3-lite-ui",
  "version": "1.0.0",
  "description": "轻量、现代、智能的 Vue 3 组件库",
  "type": "module",
  "main": "dist/vue3-lite-ui.umd.cjs",
  "module": "dist/vue3-lite-ui.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue3-lite-ui.js",
      "require": "./dist/vue3-lite-ui.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "vue3",
    "ui",
    "components",
    "typescript",
    "lightweight"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitepress-demo-preview/component": "^2.6.2",
    "@vitepress-demo-preview/plugin": "^1.4.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitepress": "^1.2.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
